{
    "rewrites": [
        {
            "source": "/",
            "destination": "/handout_gateway_black_screen/code.html"
        },
        {
            "source": "/gateway",
            "destination": "/handout_gateway_black_screen/code.html"
        },
        {
            "source": "/dashboard",
            "destination": "/handout_drop_white_dashboard/code.html"
        },
        {
            "source": "/vault",
            "destination": "/handout_drop_white_dashboard/code.html"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                }
            ]
        }
    ]
}